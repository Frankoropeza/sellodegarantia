---
/**
 * BlogSidebar — Sello de Garantía Blog Professional
 * ─────────────────────────────────────────────────
 * Sidebar sticky para blog: artículos populares, CTA WhatsApp.
 * Sin animaciones. Código limpio.
 */
interface PopularArticle {
  title: string;
  slug: string;
  category: string;
  img?: string;
}

interface Props {
  popularArticles?: PopularArticle[];
  phone?: string;
  whatsapp?: string;
  waMessage?: string;
}

const {
  popularArticles = [],
  phone = "55 5686 3599",
  whatsapp = "5215556863599",
  waMessage = "Hola, vi el blog de Sello de Garantía y quiero cotizar película de PVC.",
} = Astro.props;

const waHref = `https://wa.me/${whatsapp}?text=${encodeURIComponent(waMessage)}`;
---

<aside class="bsb">

  {/* ── Popular Articles ── */}
  {popularArticles.length > 0 && (
    <div class="bsb__card">
      <h3 class="bsb__card-title">Artículos Populares</h3>
      <ul class="bsb__pop-list">
        {popularArticles.map((art, i) => (
          <li class="bsb__pop-item">
            <a href={`/blog/${art.slug}/`} class="bsb__pop-link">
              {art.img && (
                <div class="bsb__pop-img">
                  <img src={art.img} alt={art.title} loading="lazy" width="80" height="60" />
                </div>
              )}
              <div class="bsb__pop-text">
                <span class="bsb__pop-cat">{art.category}</span>
                <span class="bsb__pop-title">{art.title}</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {/* ── CTA WhatsApp ── */}
  <div class="bsb__card bsb__cta-card">
    <div class="bsb__cta-icon">💡</div>
    <h3 class="bsb__cta-title">¿Tienes un proyecto?</h3>
    <p class="bsb__cta-text">Cotiza tu película de PVC en menos de 2 minutos. Asesoría técnica gratis.</p>
    <a href={waHref} target="_blank" rel="noopener noreferrer" class="bsb__cta-btn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Cotizar por WhatsApp
    </a>
    <a href="/cotizar/" class="bsb__cta-link">O llena el formulario →</a>
  </div>

  {/* ── Help ── */}
  <div class="bsb__card">
    <h3 class="bsb__card-title">¿Necesitas ayuda?</h3>
    <p class="bsb__help-text">Equipo técnico especializado en película de PVC. 28 años de experiencia.</p>
    <a href={`tel:+52${whatsapp}`} class="bsb__help-phone">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      {phone}
    </a>
  </div>
</aside>

<style>
  .bsb {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 0;
  }

  .bsb__card {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 12px;
    padding: 1.5rem;
  }

  .bsb__card-title {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-secondary, #1A1A2E);
    margin: 0 0 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-primary, #0047AB);
  }

  /* ── Popular Articles ── */
  .bsb__pop-list {
    list-style: none !important;
    padding: 0 !important;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .bsb__pop-item {
    padding-bottom: 0.875rem;
    border-bottom: 1px solid #f1f3f5;
  }

  .bsb__pop-item:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .bsb__pop-link {
    display: flex;
    gap: 0.75rem;
    text-decoration: none;
    align-items: flex-start;
  }

  .bsb__pop-img {
    flex-shrink: 0;
    width: 72px;
    height: 54px;
    border-radius: 6px;
    overflow: hidden;
  }

  .bsb__pop-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .bsb__pop-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .bsb__pop-cat {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary, #0047AB);
  }

  .bsb__pop-title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-secondary, #1A1A2E);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bsb__pop-link:hover .bsb__pop-title {
    color: var(--color-primary, #0047AB);
  }

  /* ── CTA Card ── */
  .bsb__cta-card {
    background: var(--color-secondary, #1A1A2E);
    border-color: transparent;
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .bsb__cta-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .bsb__cta-title {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 1.125rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .bsb__cta-text {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .bsb__cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem 1rem;
    background: #25D366;
    color: #fff;
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.2s ease;
  }

  .bsb__cta-btn:hover {
    background: #1fb855;
    color: #fff;
  }

  .bsb__cta-link {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
  }

  .bsb__cta-link:hover {
    color: #fff;
  }

  /* ── Help ── */
  .bsb__help-text {
    font-size: 0.875rem;
    color: #6c757d;
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .bsb__help-phone {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-secondary, #1A1A2E);
    text-decoration: none;
  }

  .bsb__help-phone:hover {
    color: var(--color-primary, #0047AB);
  }
</style>
