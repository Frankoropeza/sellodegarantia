---
/**
 * CtaBar Component — OrigenLab Standard
 * ─────────────────────────────────────
 * Barra de navegación por categorías debajo del Hero.
 * Objetivo: guiar al usuario a explorar antes de contactar.
 * Sin animaciones. Código limpio.
 */
interface CtaItem {
  label: string;
  href: string;
  icon?: string;
}

interface Props {
  headline?: string;
  items: CtaItem[];
}

const {
  headline = "¿Qué tipo de evento estás planeando?",
  items,
} = Astro.props;

const icons: Record<string, string> = {
  boda: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>',
  corporativo: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>',
  fiesta: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>',
  picnic: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>',
};
---

<section class="ctabar" aria-label="Tipos de evento">
  <div class="container">
    <p class="ctabar__headline">{headline}</p>
    <div class="ctabar__grid">
      {items.map((item) => (
        <a href={item.href} class="ctabar__item">
          {item.icon && icons[item.icon] && (
            <span class="ctabar__icon" set:html={icons[item.icon]} />
          )}
          <span class="ctabar__label">{item.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ctabar {
    background: var(--c-primary, #2C5530);
    padding: 2rem 0;
  }

  .ctabar__headline {
    text-align: center;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  .ctabar__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .ctabar__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-md, 12px);
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
    text-align: center;
    transition: background 0.2s var(--ease, ease), border-color 0.2s var(--ease, ease);
  }

  .ctabar__item:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .ctabar__icon {
    display: flex;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .ctabar__label {
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .ctabar__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 400px) {
    .ctabar__grid {
      grid-template-columns: 1fr;
    }

    .ctabar__item {
      padding: 0.75rem 1rem;
    }
  }
</style>
