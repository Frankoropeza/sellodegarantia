---
interface SubCategory {
  name: string;
  href: string;
}
interface Props {
  title: string;
  subtitle: string;
  href: string;
  subcategories?: SubCategory[];
}

const { title, subtitle, href, subcategories = [] } = Astro.props;
---

<div class="cat-card">
  <a href={href} class="cat-card__header">
    <h3 class="cat-card__title">{title}</h3>
    <p class="cat-card__subtitle">{subtitle}</p>
  </a>
  {subcategories.length > 0 && (
    <ul class="cat-card__list">
      {subcategories.map((sub) => (
        <li>
          <a href={sub.href} class="cat-card__link">{sub.name}</a>
        </li>
      ))}
    </ul>
  )}
</div>

<style>
  .cat-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .cat-card:hover {
    border-color: var(--color-primary);
  }
  .cat-card__header {
    display: block;
    padding: var(--space-6);
    padding-bottom: var(--space-3);
  }
  .cat-card__title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-900);
    margin-bottom: var(--space-2);
  }
  .cat-card__subtitle {
    font-size: var(--font-size-sm);
    color: var(--color-gray-600);
    line-height: var(--line-height-relaxed);
  }
  .cat-card__list {
    padding: 0 var(--space-6) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .cat-card__link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--color-primary);
    border-radius: var(--radius-sm);
  }
  .cat-card__link:hover {
    background: var(--color-gray-50);
  }
</style>
