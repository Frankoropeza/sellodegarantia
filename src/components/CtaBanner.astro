---
interface Props {
  /** Headline principal */
  title: string;
  /** Texto descriptivo debajo del headline */
  subtitle?: string;
  /** Texto del boton principal */
  btnText?: string;
  /** URL del boton principal */
  btnHref?: string;
  /** Texto del boton secundario */
  btnSecondaryText?: string;
  /** URL del boton secundario */
  btnSecondaryHref?: string;
  /** Variante de color: 'vibrant' | 'warm' | 'cool' | 'festa' */
  variant?: "vibrant" | "warm" | "cool" | "festa";
  /** Mostrar icono de WhatsApp en el boton principal */
  whatsapp?: boolean;
  /** Abrir enlace principal en nueva pestaña */
  external?: boolean;
  /** Compacto (menos padding, ideal entre secciones) */
  compact?: boolean;
}

const {
  title,
  subtitle,
  btnText,
  btnHref,
  btnSecondaryText,
  btnSecondaryHref,
  variant = "vibrant",
  whatsapp = false,
  external = false,
  compact = false,
} = Astro.props;

const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---

<section class={`cta-banner cta-banner--${variant}${compact ? " cta-banner--compact" : ""}`}>
  <!-- Decorative shapes -->
  <div class="cta-banner__shape cta-banner__shape--1"></div>
  <div class="cta-banner__shape cta-banner__shape--2"></div>
  <div class="cta-banner__shape cta-banner__shape--3"></div>

  <div class="container">
    <div class="cta-banner__content">
      <div class="cta-banner__text">
        <h2 class="cta-banner__title">{title}</h2>
        {subtitle && <p class="cta-banner__subtitle">{subtitle}</p>}
      </div>
      {(btnText || btnSecondaryText) && (
        <div class="cta-banner__actions">
          {btnText && btnHref && (
            <a href={btnHref} class="cta-banner__btn cta-banner__btn--primary" target={target} rel={rel}>
              {whatsapp && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              )}
              {btnText}
            </a>
          )}
          {btnSecondaryText && btnSecondaryHref && (
            <a href={btnSecondaryHref} class="cta-banner__btn cta-banner__btn--secondary">
              {btnSecondaryText}
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  /* ── CTA Banner Component ── */
  .cta-banner {
    position: relative;
    overflow: hidden;
    padding: 3rem 0;
    isolation: isolate;
  }

  .cta-banner--compact {
    padding: 2rem 0;
  }

  /* ── Variantes de color ── */
  .cta-banner--vibrant {
    background: linear-gradient(135deg, #FF3D00 0%, #FF6D00 25%, #7C3AED 50%, #E91E8C 75%, #FF3D00 100%);
  }

  .cta-banner--warm {
    background: linear-gradient(135deg, #FF3D00 0%, #FF6F00 30%, #FFD600 60%, #FF3D00 100%);
  }

  .cta-banner--cool {
    background: linear-gradient(135deg, #0288D1 0%, #7C3AED 40%, #1565C0 70%, #0288D1 100%);
  }

  .cta-banner--festa {
    background: linear-gradient(135deg, #FF3D00 0%, #E91E8C 20%, #7C3AED 40%, #0288D1 60%, #00C853 80%, #FFD600 100%);
  }

  /* ── Formas decorativas ── */
  .cta-banner__shape {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
  }

  .cta-banner__shape--1 {
    width: 200px;
    height: 200px;
    background: rgba(255, 255, 255, 0.08);
    top: -60px;
    right: 5%;
  }

  .cta-banner__shape--2 {
    width: 120px;
    height: 120px;
    background: rgba(255, 255, 255, 0.06);
    bottom: -40px;
    left: 10%;
  }

  .cta-banner__shape--3 {
    width: 80px;
    height: 80px;
    background: rgba(255, 255, 255, 0.1);
    top: 20%;
    left: 30%;
  }

  /* ── Layout del contenido ── */
  .cta-banner__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    position: relative;
    z-index: 1;
  }

  .cta-banner__text {
    flex: 1;
    min-width: 0;
  }

  .cta-banner__title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    color: #fff;
    line-height: 1.2;
    margin: 0;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .cta-banner__subtitle {
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    color: rgba(255, 255, 255, 0.9);
    margin: 0.5rem 0 0;
    line-height: 1.5;
    max-width: 600px;
  }

  /* ── Botones ── */
  .cta-banner__actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    border-radius: var(--r-btn);
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.25s ease;
    white-space: nowrap;
    line-height: 1.2;
    cursor: pointer;
  }

  .cta-banner__btn--primary {
    background: #fff;
    color: var(--c-primary);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
  }

  .cta-banner__btn--primary:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
  }

  .cta-banner__btn--secondary {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(4px);
  }

  .cta-banner__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: #fff;
    transform: translateY(-2px);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .cta-banner__content {
      flex-direction: column;
      text-align: center;
    }

    .cta-banner__subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .cta-banner__actions {
      justify-content: center;
      width: 100%;
    }

    .cta-banner__btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
