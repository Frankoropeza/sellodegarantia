---
interface Props {
  title: string;
  subtitle?: string;
  btnText: string;
  btnHref: string;
  variant?: 'primary' | 'accent';
}

const { title, subtitle, btnText, btnHref, variant = 'primary' } = Astro.props;
const bgClass = variant === 'accent' ? 'cta-banner--accent' : 'cta-banner--primary';
---

<section class={`cta-banner ${bgClass}`}>
  <div class="cta-banner__inner">
    <div class="cta-banner__text">
      <h2 class="cta-banner__title">{title}</h2>
      {subtitle && <p class="cta-banner__subtitle">{subtitle}</p>}
    </div>
    <a href={btnHref} class="btn btn--primary btn--lg cta-banner__btn">{btnText}</a>
  </div>
</section>

<style>
  .cta-banner {
    padding: var(--space-12) 0;
    color: var(--color-white);
  }
  .cta-banner--primary {
    background: var(--color-primary);
  }
  .cta-banner--accent {
    background: var(--color-accent);
  }
  .cta-banner__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
  }
  .cta-banner__title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-2);
  }
  .cta-banner__subtitle {
    font-size: var(--font-size-base);
    opacity: 0.9;
  }
  .cta-banner--accent .cta-banner__btn {
    background: var(--color-white);
    color: var(--color-accent);
  }
  .cta-banner--accent .cta-banner__btn:hover {
    background: var(--color-gray-100);
  }
</style>
