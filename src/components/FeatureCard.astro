---
/**
 * FeatureCard — OrigenLab Standard
 * Card de diferenciador con imagen, título H3 y descripción.
 * Misma estética que ServiceCard pero sin botón.
 * Sin animaciones. Código limpio.
 */
interface Props {
  title: string;
  description: string;
  image?: string;
}

const {
  title,
  description,
  image,
} = Astro.props;
---

<div class="fc">
  <div class="fc__img">
    {image ? (
      <img src={image} alt={title} loading="lazy" width="400" height="225" />
    ) : (
      <div class="fc__placeholder" aria-hidden="true">
        <span>Imagen</span>
      </div>
    )}
  </div>
  <div class="fc__body">
    <h3 class="fc__title">{title}</h3>
    <p class="fc__desc">{description}</p>
  </div>
</div>

<style>
  .fc {
    background: #fff;
    border: 1px solid var(--c-border, #E7E0D8);
    border-radius: var(--radius-md, 12px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .fc__img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .fc__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .fc__placeholder {
    width: 100%;
    height: 100%;
    background: var(--c-bg-alt, #F7F4F0);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-text-muted, #78716C);
    font-size: 0.8125rem;
    font-weight: 500;
  }

  .fc__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .fc__title {
    font-size: 1.125rem;
    color: var(--c-text, #1C1917);
    margin-bottom: 0.625rem;
    line-height: 1.3;
  }

  .fc__desc {
    font-size: 0.875rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.7;
  }
</style>
