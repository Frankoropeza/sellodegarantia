---
import { PHONE, PHONE_HREF, WHATSAPP, EMAIL, HOURS } from '../lib/config';

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
const waHref = `https://wa.me/${WHATSAPP}`;
---

<div class="faq-layout container">

  <!-- COLUMNA 1: FAQ -->
  <div class="faq-layout__faqs">
    {items.map((item) => (
      <details class="faq-item">
        <summary class="faq-item__q">{item.question}</summary>
        <div class="faq-item__a">
          <p>{item.answer}</p>
        </div>
      </details>
    ))}
  </div>

  <!-- COLUMNA 2: Contacto + Formulario WA -->
  <div class="faq-layout__contact">
    <div class="faq-contact">
      <h3 class="faq-contact__title">¿No encuentra su respuesta?</h3>
      <p class="faq-contact__desc">Escríbanos por WhatsApp y le respondemos en minutos.</p>

      <div class="faq-contact__info">
        <a href={PHONE_HREF} class="faq-contact__item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <span>{PHONE}</span>
        </a>
        <div class="faq-contact__item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>{HOURS.display}</span>
        </div>
      </div>

      <!-- Mini formulario WA -->
      <form class="faq-form" id="faqWaForm">
        <label for="faqName" class="faq-form__label">Su nombre</label>
        <input type="text" id="faqName" class="faq-form__input" placeholder="Ej: Juan Pérez" required />

        <label for="faqProduct" class="faq-form__label">Producto de interés</label>
        <select id="faqProduct" class="faq-form__input">
          <option value="Sellos de garantía">Sellos de garantía</option>
          <option value="Mangas retráctiles">Mangas retráctiles</option>
          <option value="Etiquetas impresas">Etiquetas impresas</option>
          <option value="Preformas y cápsulas">Preformas y cápsulas</option>
          <option value="Película en rollo">Película en rollo</option>
          <option value="Maquinaria">Maquinaria de aplicación</option>
          <option value="Otro">Otro / No sé</option>
        </select>

        <label for="faqMsg" class="faq-form__label">Su pregunta</label>
        <textarea id="faqMsg" class="faq-form__input faq-form__textarea" placeholder="Escriba su duda aquí..." rows="3"></textarea>

        <button type="submit" class="faq-form__btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Enviar por WhatsApp
        </button>
      </form>
    </div>
  </div>

</div>

<script is:inline>
  document.getElementById('faqWaForm').addEventListener('submit', function(e) {
    e.preventDefault();
    var name = document.getElementById('faqName').value.trim();
    var product = document.getElementById('faqProduct').value;
    var msg = document.getElementById('faqMsg').value.trim();
    var text = 'Hola, soy ' + name + '. Me interesa: ' + product + '.';
    if (msg) text += ' Mi pregunta: ' + msg;
    var wa = 'https://wa.me/5215556863599?text=' + encodeURIComponent(text);
    window.open(wa, '_blank');
  });
</script>

<style>
  .faq-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
  }
  .faq-layout__faqs {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .faq-item {
    background: #fff;
    border: 1px solid var(--color-gray-200, #E2E8F0);
    border-radius: 8px;
    overflow: hidden;
  }
  .faq-item__q {
    padding: 1.125rem 1.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-gray-900, #0F172A);
  }
  .faq-item__q::-webkit-details-marker { display: none; }
  .faq-item__q::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--color-gray-600, #475569);
    flex-shrink: 0;
    margin-left: 1rem;
  }
  .faq-item[open] .faq-item__q::after { content: '−'; }
  .faq-item[open] .faq-item__q { background: var(--color-gray-50, #F8FAFC); }
  .faq-item__a {
    padding: 0 1.5rem 1.125rem;
    color: var(--color-gray-600, #475569);
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  /* Sidebar contacto */
  .faq-contact {
    background: #fff;
    border: 1px solid var(--color-gray-200, #E2E8F0);
    border-radius: 12px;
    padding: 2rem;
    position: sticky;
    top: calc(var(--header-height, 70px) + 1.5rem);
  }
  .faq-contact__title {
    font-size: 1.125rem;
    color: var(--color-gray-900, #0F172A);
    margin-bottom: 0.5rem;
  }
  .faq-contact__desc {
    font-size: 0.875rem;
    color: var(--color-gray-600, #475569);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }
  .faq-contact__info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-gray-200, #E2E8F0);
  }
  .faq-contact__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-gray-900, #0F172A);
  }
  .faq-contact__item svg {
    color: var(--color-primary, #0047AB);
    flex-shrink: 0;
  }

  /* Formulario */
  .faq-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .faq-form__label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-gray-900, #0F172A);
    margin-top: 0.25rem;
  }
  .faq-form__input {
    width: 100%;
    padding: 0.7rem 0.875rem;
    border: 1px solid var(--color-gray-200, #E2E8F0);
    border-radius: 8px;
    font-size: 0.875rem;
    font-family: 'Inter', sans-serif;
    color: var(--color-gray-900, #0F172A);
    background: #fff;
  }
  .faq-form__input:focus {
    outline: none;
    border-color: var(--color-primary, #0047AB);
  }
  .faq-form__textarea {
    resize: vertical;
    min-height: 70px;
  }
  .faq-form__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.8rem 1rem;
    margin-top: 0.5rem;
    background: #25D366;
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: background 0.2s;
  }
  .faq-form__btn:hover { background: #1fb855; }

  @media (max-width: 1024px) {
    .faq-layout { grid-template-columns: 1fr 320px; gap: 2rem; }
  }
  @media (max-width: 768px) {
    .faq-layout { grid-template-columns: 1fr; }
    .faq-contact { position: static; }
  }
</style>
