---
interface Metric {
  value: string;
  label: string;
}
interface Cta {
  text: string;
  href: string;
}
interface Props {
  title: string;
  description: string;
  badge?: string;
  metrics?: Metric[];
  primaryCta?: Cta;
  secondaryCta?: Cta;
}

const {
  title,
  description,
  badge,
  metrics = [],
  primaryCta,
  secondaryCta,
} = Astro.props;
---

<section class="hero">
  <div class="hero__inner">
    <div class="hero__col1">
      {badge && <span class="hero__badge">{badge}</span>}
      <h1 class="hero__title">{title}</h1>
      <p class="hero__desc">{description}</p>
      <div class="hero__ctas">
        {primaryCta && <a href={primaryCta.href} class="btn btn--primary btn--lg">{primaryCta.text}</a>}
        {secondaryCta && <a href={secondaryCta.href} class="btn btn--secondary btn--lg">{secondaryCta.text}</a>}
      </div>
      {metrics.length > 0 && (
        <div class="hero__metrics">
          {metrics.map((m) => (
            <div class="hero__metric">
              <span class="hero__metric-value">{m.value}</span>
              <span class="hero__metric-label">{m.label}</span>
            </div>
          ))}
        </div>
      )}
    </div>
    <div class="hero__col2">
      <slot name="hero-seo" />
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    color: var(--color-white);
    padding: var(--space-16) 0;
  }
  .hero__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .hero__badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    color: var(--color-white);
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    margin-bottom: var(--space-4);
  }
  .hero__title {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    margin-bottom: var(--space-4);
  }
  .hero__desc {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    opacity: 0.9;
    margin-bottom: var(--space-6);
    max-width: 540px;
  }
  .hero__ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }
  .hero__metrics {
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
  }
  .hero__metric {
    display: flex;
    flex-direction: column;
  }
  .hero__metric-value {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
  }
  .hero__metric-label {
    font-size: var(--font-size-xs);
    opacity: 0.75;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (min-width: 900px) {
    .hero {
      padding: var(--space-20) 0;
    }
    .hero__inner {
      grid-template-columns: 1fr 1fr;
    }
    .hero__title {
      font-size: var(--font-size-5xl);
    }
  }
</style>
