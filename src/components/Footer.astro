---
import { SITE_NAME, PHONE, PHONE_HREF, EMAIL, LOCATION, CATEGORIES, INDUSTRIES } from '../lib/config';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__grid">
      <!-- Brand + Contact -->
      <div class="footer__col">
        <p class="footer__brand">◆ {SITE_NAME}</p>
        <p class="footer__text">Fabricantes de película de PVC termoencogible y sellos de garantía desde 1998.</p>
        <div class="footer__contact">
          <a href={PHONE_HREF}>📞 {PHONE}</a>
          <a href={`mailto:${EMAIL}`}>✉️ {EMAIL}</a>
          <p>📍 {LOCATION.full}</p>
        </div>
      </div>

      <!-- Productos -->
      <div class="footer__col">
        <h4 class="footer__heading">Productos</h4>
        <ul class="footer__links">
          {CATEGORIES.map((cat) => (
            <li><a href={`/productos/${cat.slug}/`}>{cat.title}</a></li>
          ))}
        </ul>
      </div>

      <!-- Industrias -->
      <div class="footer__col">
        <h4 class="footer__heading">Industrias</h4>
        <ul class="footer__links">
          {INDUSTRIES.slice(0, 6).map((ind) => (
            <li><a href={ind.href}>{ind.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Empresa -->
      <div class="footer__col">
        <h4 class="footer__heading">Empresa</h4>
        <ul class="footer__links">
          <li><a href="/nosotros/">Nosotros</a></li>
          <li><a href="/contacto/">Contacto</a></li>
          <li><a href="/cotizar/">Solicitar Cotización</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p>© {year} {SITE_NAME}. Todos los derechos reservados.</p>
      <a href="/aviso-de-privacidad/">Aviso de Privacidad</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark);
    color: var(--color-gray-400);
    padding: var(--space-16) 0 0;
  }
  .footer__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    padding-bottom: var(--space-12);
  }
  .footer__brand {
    color: var(--color-white);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-3);
  }
  .footer__text {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-4);
  }
  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
  }
  .footer__contact a:hover { color: var(--color-white); }
  .footer__heading {
    color: var(--color-white);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
  }
  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .footer__links a {
    font-size: var(--font-size-sm);
  }
  .footer__links a:hover { color: var(--color-white); }
  .footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: var(--space-6) 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    font-size: var(--font-size-xs);
  }
  .footer__bottom a:hover { color: var(--color-white); }

  @media (min-width: 640px) {
    .footer__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .footer__grid { grid-template-columns: 2fr 1fr 1fr 1fr; }
  }
</style>
