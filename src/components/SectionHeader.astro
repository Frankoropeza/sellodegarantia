---
/**
 * SectionHeader Component — OrigenLab Standard
 * ─────────────────────────────────────────────
 * Título de sección en 2 columnas:
 *   Col 1: Heading (H2-H6 configurable)
 *   Col 2: Dos párrafos descriptivos
 * Respeta jerarquía SEO: H1 solo en Hero, secciones usan H2+
 * Sin animaciones. Código limpio.
 */
interface Props {
  tag?: 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
  title: string;
  paragraph1: string;
  paragraph2: string;
}

const {
  tag = 'h2',
  title,
  paragraph1,
  paragraph2,
} = Astro.props;

const Tag = tag;
---

<div class="sh">
  <div class="container sh__grid">
    <div class="sh__col1">
      <Tag class="sh__title">{title}</Tag>
    </div>
    <div class="sh__col2">
      <p class="sh__text">{paragraph1}</p>
      <p class="sh__text">{paragraph2}</p>
    </div>
  </div>
</div>

<style>
  .sh {
    padding-bottom: 2.5rem;
  }

  .sh__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .sh__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: var(--c-text, #1C1917);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .sh__col2 {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sh__text {
    font-size: 0.9375rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.75;
  }

  @media (max-width: 768px) {
    .sh__grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
</style>
