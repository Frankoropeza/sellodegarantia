---
/**
 * ServiceCard — OrigenLab Standard
 * ────────────────────────────────
 * Card de servicio con imagen, título H3, extracto SEO
 * y botón full-width. Sin animaciones.
 */
interface Props {
  title: string;
  description: string;
  image: string;
  href: string;
  btnLabel?: string;
}

const {
  title,
  description,
  image,
  href,
  btnLabel = "Ver detalles del servicio",
} = Astro.props;
---

<div class="sc">
  <div class="sc__img">
    <img src={image} alt={title} loading="lazy" width="400" height="225" />
  </div>
  <div class="sc__body">
    <h3 class="sc__title">{title}</h3>
    <p class="sc__desc">{description}</p>
    <a href={href} class="sc__btn">{btnLabel}</a>
  </div>
</div>

<style>
  .sc {
    background: #fff;
    border: 1px solid var(--c-border, #E7E0D8);
    border-radius: var(--radius-md, 12px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .sc__img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .sc__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sc__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .sc__title {
    font-size: 1.125rem;
    color: var(--c-text, #1C1917);
    margin-bottom: 0.625rem;
    line-height: 1.3;
  }

  .sc__desc {
    font-size: 0.875rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.7;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .sc__btn {
    display: block;
    width: 100%;
    padding: 0.8rem 1rem;
    background: var(--c-primary, #2C5530);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    text-align: center;
    border-radius: var(--radius-sm, 8px);
    letter-spacing: 0.01em;
    transition: background 0.2s var(--ease, ease);
  }

  .sc__btn:hover {
    background: var(--c-primary-light, #3D7A45);
  }
</style>
