---
import Base from '../../layouts/Base.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import FaqSection from '../../components/FaqSection.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBubble from '../../components/WhatsAppBubble.astro';

import { SITE_NAME } from '../../lib/config';
import { organizationSchema, localBusinessSchema, serviceSchema, faqSchema, breadcrumbSchema } from '../../lib/seo';

const breadcrumbs = [
  { text: 'Inicio', href: '/' },
  { text: 'Industrias', href: '/industrias/' },
  { text: 'Farmacéutica', href: '/industrias/farmaceutica/' },
];

const faqs = [
  {
    question: '¿Los sellos de garantía cumplen con COFEPRIS?',
    answer: 'Sí. Nuestra película PVC es grado alimenticio y cumple los requerimientos para contacto indirecto con medicamentos, suplementos y dispositivos médicos. Proporcionamos fichas técnicas del material para sus trámites regulatorios ante COFEPRIS.',
  },
  {
    question: '¿Qué calibre de sello se usa en frascos farmacéuticos?',
    answer: 'Para frascos de medicamento usamos calibre 40-50 micras. Estos calibres ofrecen contracción uniforme sobre tapas pequeñas (20-40mm) y evidencian apertura sin residuos. El calibre exacto depende del diámetro de su frasco y la velocidad de su línea.',
  },
  {
    question: '¿Pueden imprimir datos legales y lote en el sello?',
    answer: 'Sí. Nuestro sistema de impresión rotograbado a 6 tintas reproduce logotipos, datos legales, número de lote, código de barras y cualquier información requerida por la normativa farmacéutica. La impresión es resistente al calor de aplicación.',
  },
  {
    question: '¿Cuál es el pedido mínimo para sellos farmacéuticos?',
    answer: 'Para sellos lisos el mínimo es 5,000 piezas. Para sellos impresos el mínimo es 10,000 piezas. Fabricamos tirajes desde pruebas piloto hasta millones de piezas para líneas de producción continua.',
  },
  {
    question: '¿Ofrecen fichas técnicas para registro sanitario?',
    answer: 'Sí. Entregamos ficha técnica del material PVC, certificado de grado alimenticio y especificaciones de encogimiento. Estos documentos son los que COFEPRIS solicita como parte del expediente de registro sanitario de medicamentos y suplementos.',
  },
  {
    question: '¿Qué tiempo de entrega manejan para laboratorios?',
    answer: 'Sellos lisos se entregan en 3-5 días hábiles. Sellos impresos tardan 10-15 días hábiles según la complejidad del diseño. Para laboratorios con requerimientos urgentes ofrecemos programas de producción continua con entregas semanales.',
  },
];

const productos = [
  {
    title: 'Sello Farmacéutico',
    description: 'Sello de garantía PVC grado alimenticio para frascos de medicamento. Calibre 40-50 micras, compatible COFEPRIS.',
    href: '/productos/sello-farmaceutico/',
    image: '/img/productos/sello-frasco-farmaceutico.avif',
  },
  {
    title: 'Sello Impreso a 6 Tintas',
    description: 'Logotipo, datos legales, código de barras y número de lote impresos por rotograbado sobre película PVC.',
    href: '/productos/sello-impreso-6-tintas/',
    image: '/img/productos/sello-impreso-6-tintas-pvc.avif',
  },
  {
    title: 'Sello con Perforación',
    description: 'Micro-perforación para apertura fácil sin herramientas. Evidencia de apertura inmediata para seguridad del paciente.',
    href: '/productos/sello-perforado/',
    image: '/img/productos/sello-perforado-pvc.avif',
  },
  {
    title: 'Sello Liso Transparente',
    description: 'Sello cristal para inviolabilidad básica en frascos y envases farmacéuticos. Desde 5,000 piezas.',
    href: '/productos/sello-liso-transparente/',
    image: '/img/productos/sello-liso-transparente-pvc.avif',
  },
];

const structuredData = [
  organizationSchema(),
  localBusinessSchema(),
  serviceSchema({
    name: 'Sellos de Garantía para Industria Farmacéutica',
    description: 'Fabricación de sellos de garantía PVC termoencogible grado alimenticio para laboratorios farmacéuticos. Cumplimiento COFEPRIS, impresión rotograbado a 6 tintas, calibres 40-80 micras.',
    url: '/industrias/farmaceutica/',
    category: 'Sellos de Garantía Farmacéuticos',
  }),
  faqSchema(faqs),
  breadcrumbSchema(breadcrumbs),
];
---

<Base
  title="Sellos de Garantía Farmacéuticos COFEPRIS"
  description="Sellos de garantía PVC para laboratorios farmacéuticos. Grado alimenticio, compatible COFEPRIS. Impresión a 6 tintas. Fabricante directo 28 años."
  structuredData={structuredData}
>
  <TopBar />
  <Header />

  <Breadcrumb items={breadcrumbs} />

  <Hero
    badge="Industria Farmacéutica"
    title="¿Qué sellos de garantía necesita la industria farmacéutica?"
    description="Fabricamos sellos de garantía de PVC termoencogible grado alimenticio para laboratorios farmacéuticos en México. Cumplimiento COFEPRIS, impresión de datos legales y lote, calibres de 40 a 80 micras."
    primaryCta={{ text: 'Cotizar Sellos Farmacéuticos', href: '/cotizar/' }}
    secondaryCta={{ text: 'Pedir Muestras Gratis', href: '/contacto/' }}
    metrics={[
      { value: '28', label: 'Años' },
      { value: '40-50', label: 'Micras' },
      { value: '6', label: 'Tintas' },
      { value: '5K', label: 'Mín. pzas' },
    ]}
  >
    <Fragment slot="hero-seo">
      <div class="hero-seo">
        <p class="hero-seo__text">
          La industria farmacéutica mexicana requiere sellos de garantía que cumplan con la normativa COFEPRIS para contacto indirecto con medicamentos. Un sello deficiente en un frasco farmacéutico puede significar una observación regulatoria, un retiro de producto o la pérdida de confianza del paciente. En Sello de Garantía fabricamos bandas termoencogibles de PVC grado alimenticio específicamente para este sector desde hace 28 años.
        </p>
        <p class="hero-seo__text">
          Nuestros sellos farmacéuticos se fabrican en calibres de 40 y 50 micras para frascos de 20mm a 60mm de diámetro. Imprimimos datos legales, logotipo, número de lote y código de barras por rotograbado a 6 tintas. Tumipack México SA de CV entrega fichas técnicas del material para expedientes de registro sanitario. Planta propia en Iztapalapa, CDMX con envíos a los 32 estados.
        </p>
      </div>
    </Fragment>
  </Hero>

  <CtaBanner
    title="¿Necesita sellos para su laboratorio farmacéutico?"
    subtitle="Fichas técnicas incluidas para trámites COFEPRIS. Muestras sin costo."
    btnText="Solicitar Cotización"
    btnHref="/cotizar/"
    variant="accent"
  />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Productos Recomendados"
        title="¿Qué productos de PVC usa la farmacéutica?"
        subtitle="Sellos de garantía diseñados para frascos de medicamento, suplementos y dispositivos médicos. Todos con ficha técnica para COFEPRIS."
      />
      <div class="grid-2">
        {productos.map((p) => (
          <ServiceCard
            title={p.title}
            description={p.description}
            href={p.href}
            image={p.image}
          />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    title="Fabricante directo de sellos farmacéuticos"
    subtitle="28 años fabricando para laboratorios en México. Precios de planta."
    btnText="Cotizar Ahora"
    btnHref="/cotizar/"
    variant="primary"
  />

  <section class="section" id="faq">
    <div class="container">
      <SectionHeader
        badge="Preguntas Frecuentes"
        title="¿Qué preguntan los laboratorios farmacéuticos?"
        subtitle="Las dudas más comunes sobre sellos de garantía para medicamentos, normativa COFEPRIS y fichas técnicas."
      />
    </div>
    <FaqSection items={faqs} />
  </section>

  <CtaBanner
    title="Proteja sus medicamentos con el sello correcto"
    subtitle="Asesoría técnica, fichas para COFEPRIS y muestras sin costo."
    btnText="Contactar Ahora"
    btnHref="/contacto/"
    variant="accent"
  />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .hero-seo {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .hero-seo__text {
    background: rgba(255, 255, 255, 0.08);
    padding: var(--space-5);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: rgba(255, 255, 255, 0.88);
  }
</style>
