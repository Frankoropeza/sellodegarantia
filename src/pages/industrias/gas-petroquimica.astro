---
import Base from '../../layouts/Base.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import FaqSection from '../../components/FaqSection.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBubble from '../../components/WhatsAppBubble.astro';

import { SITE_NAME } from '../../lib/config';
import { organizationSchema, localBusinessSchema, serviceSchema, faqSchema, breadcrumbSchema } from '../../lib/seo';

const breadcrumbs = [
  { text: 'Inicio', href: '/' },
  { text: 'Industrias', href: '/industrias/' },
  { text: 'Gas y Petroquímica', href: '/industrias/gas-petroquimica/' },
];

const faqs = [
  {
    question: '¿Qué sellos se usan en contenedores de gas LP?',
    answer: 'Para contenedores de gas LP usamos sellos de PVC termoencogible en calibre 60-80 micras. Estos calibres resisten las condiciones de manejo, almacenamiento a intemperie y transporte de cilindros de gas. El sello evidencia cualquier intento de apertura o rellenado no autorizado.',
  },
  {
    question: '¿Los sellos resisten condiciones de intemperie?',
    answer: 'Sí. Nuestros sellos en calibre 80 micras están diseñados para resistir exposición solar, lluvia y cambios de temperatura. La película PVC mantiene sus propiedades mecánicas en condiciones de almacenamiento y transporte normales de la industria gasera.',
  },
  {
    question: '¿Pueden imprimir el logotipo de la gasera en el sello?',
    answer: 'Sí. Imprimimos por rotograbado a 6 tintas el logotipo de su empresa, número de permiso, datos legales y cualquier información requerida. Un sello impreso refuerza la marca y permite al consumidor identificar el origen del producto.',
  },
  {
    question: '¿Qué pedido mínimo manejan para gaseras?',
    answer: 'Para sellos lisos el mínimo es 5,000 piezas. Para sellos impresos el mínimo es 10,000 piezas. Para gaseras con alto volumen de distribución ofrecemos precios por volumen y entregas programadas semanales.',
  },
  {
    question: '¿También fabrican sellos para productos químicos industriales?',
    answer: 'Sí. Fabricamos sellos para contenedores de aditivos, solventes, lubricantes y productos químicos. Los sellos de alta resistencia (calibre 60-80 micras) garantizan la integridad del producto durante almacenamiento y transporte.',
  },
  {
    question: '¿Qué equipo de aplicación recomiendan para cilindros de gas?',
    answer: 'Para cilindros de gas recomendamos pistola de calor industrial para tirajes bajos o túnel de calor para líneas de llenado automatizadas. Fabricamos ambos equipos y los calibramos para el diámetro de la válvula de su cilindro.',
  },
];

const productos = [
  {
    title: 'Sello Liso de Color',
    description: 'Sello de PVC pigmentado en colores corporativos para cilindros de gas LP. Calibre 60-80 micras, alta resistencia.',
    href: '/productos/sello-liso-color/',
    image: '/img/productos/sello-liso-color-pvc.avif',
  },
  {
    title: 'Sello Impreso a 6 Tintas',
    description: 'Sello con logotipo, número de permiso y datos legales de su empresa gasera. Impresión rotograbado resistente.',
    href: '/productos/sello-impreso-6-tintas/',
    image: '/img/productos/sello-impreso-6-tintas-pvc.avif',
  },
  {
    title: 'Sello con Perforación',
    description: 'Sello con micro-perforación para evidencia de apertura en contenedores de gas y productos químicos.',
    href: '/productos/sello-perforado/',
    image: '/img/productos/sello-perforado-pvc.avif',
  },
  {
    title: 'Pistola de Calor Industrial',
    description: 'Equipo portátil para aplicación de sellos en cilindros de gas. Ideal para puntos de llenado con bajo volumen.',
    href: '/productos/pistola-calor-industrial/',
    image: '/img/productos/sello-liso-transparente-pvc.avif',
  },
];

const structuredData = [
  organizationSchema(),
  localBusinessSchema(),
  serviceSchema({
    name: 'Sellos de Garantía para Gas LP y Petroquímica',
    description: 'Fabricación de sellos de garantía PVC de alta resistencia para contenedores de gas LP, aditivos y productos químicos industriales. Calibres 60-80 micras.',
    url: '/industrias/gas-petroquimica/',
    category: 'Sellos para Gas y Petroquímica',
  }),
  faqSchema(faqs),
  breadcrumbSchema(breadcrumbs),
];
---

<Base
  title="Sellos de Garantía para Gas LP y Petroquímica"
  description="Sellos de garantía PVC alta resistencia para gas LP y productos químicos. Calibre 60-80 micras. Fabricante directo 28 años. Envíos a 32 estados."
  structuredData={structuredData}
>
  <TopBar />
  <Header />

  <Breadcrumb items={breadcrumbs} />

  <Hero
    badge="Gas y Petroquímica"
    title="¿Qué sellos de garantía usa la industria del gas LP?"
    description="Fabricamos sellos de PVC termoencogible de alta resistencia para contenedores de gas LP, aditivos y productos químicos industriales. Calibres 60-80 micras que resisten intemperie, transporte y manejo brusco."
    primaryCta={{ text: 'Cotizar Sellos para Gas', href: '/cotizar/' }}
    secondaryCta={{ text: 'Pedir Muestras Gratis', href: '/contacto/' }}
    metrics={[
      { value: '60-80', label: 'Micras' },
      { value: '28', label: 'Años' },
      { value: '6', label: 'Tintas' },
      { value: '32', label: 'Estados' },
    ]}
  >
    <Fragment slot="hero-seo">
      <div class="hero-seo">
        <p class="hero-seo__text">
          La industria gasera y petroquímica requiere sellos que resistan condiciones extremas: intemperie, golpes en transporte, apilamiento de cilindros y cambios de temperatura. Un sello que se rompe antes de llegar al consumidor es un problema de seguridad y de marca. En Sello de Garantía fabricamos bandas termoencogibles de PVC en calibre 60-80 micras específicamente para esta industria desde hace 28 años.
        </p>
        <p class="hero-seo__text">
          Nuestros sellos para gas LP se fabrican a la medida de la válvula del cilindro y resisten las condiciones normales de distribución. Imprimimos logotipo, número de permiso y datos de la empresa gasera por rotograbado a 6 tintas. Tumipack México SA de CV atiende gaseras, distribuidoras de aditivos y empresas petroquímicas en los 32 estados de México.
        </p>
      </div>
    </Fragment>
  </Hero>

  <CtaBanner
    title="¿Necesita sellos para su gasera o empresa petroquímica?"
    subtitle="Alta resistencia. Precios de fábrica. Entregas programadas."
    btnText="Solicitar Cotización"
    btnHref="/cotizar/"
    variant="accent"
  />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Productos Recomendados"
        title="¿Qué productos de PVC usa la industria del gas?"
        subtitle="Sellos de alta resistencia y equipos de aplicación para cilindros de gas LP y contenedores químicos."
      />
      <div class="grid-2">
        {productos.map((p) => (
          <ServiceCard
            title={p.title}
            description={p.description}
            href={p.href}
            image={p.image}
          />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    title="Fabricante directo de sellos para la industria gasera"
    subtitle="28 años fabricando sellos de alta resistencia para gas LP."
    btnText="Cotizar Ahora"
    btnHref="/cotizar/"
    variant="primary"
  />

  <section class="section" id="faq">
    <div class="container">
      <SectionHeader
        badge="Preguntas Frecuentes"
        title="¿Qué preguntan las empresas gaseras?"
        subtitle="Dudas comunes sobre sellos para gas LP, resistencia, impresión y equipos de aplicación."
      />
    </div>
    <FaqSection items={faqs} />
  </section>

  <CtaBanner
    title="Proteja sus cilindros con el sello correcto"
    subtitle="Alta resistencia, impresión corporativa, entrega nacional."
    btnText="Contactar Ahora"
    btnHref="/contacto/"
    variant="accent"
  />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .hero-seo {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .hero-seo__text {
    background: rgba(255, 255, 255, 0.08);
    padding: var(--space-5);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: rgba(255, 255, 255, 0.88);
  }
</style>
