---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';
import WaBubble from '../../components/WaBubble.astro';
import '../../styles/global.css';

const WA = "5215556863599";

const productos = [
  {
    title: "Sellos de Garantía",
    description: "Bandas de PVC termoencogible que se colocan sobre la tapa del envase. Al aplicar calor, se contraen y sellan la unión entre tapa y envase, evidenciando cualquier intento de apertura.",
    image: "/img/productos/sellos-de-garantia-pvc-termoencogible.avif",
    href: "/productos/sellos-de-garantia"
  },
  {
    title: "Mangas Termoencogibles",
    description: "Película tubular que envuelve el envase de cuerpo completo. Funciona como etiqueta, protección y sello de seguridad al mismo tiempo. Ideal para productos que necesitan máxima presentación.",
    image: "/img/productos/mangas-termoencogibles-pvc.avif",
    href: "/productos/mangas-termoencogibles"
  },
  {
    title: "Etiquetas Impresas a 6 Tintas",
    description: "Impresión de alta calidad sobre película PVC termoencogible. Logos, información del producto, códigos de barras, datos regulatorios y diseños a todo color que se adaptan a la forma del envase.",
    image: "/img/productos/etiquetas-impresas-pvc-6-tintas.avif",
    href: "/productos/etiquetas-impresas"
  },
  {
    title: "Preformados",
    description: "Sellos y mangas pre-cortados y pre-formados a las dimensiones exactas de tu envase. Listos para aplicar con pistola de calor o túnel. Reducen desperdicio y aceleran la línea de producción.",
    image: "/img/productos/preformados-pvc-termoencogible.avif",
    href: "/productos/preformados"
  },
  {
    title: "Bobinas para Máquinas Automáticas",
    description: "Rollos continuos de película PVC termoencogible, con o sin impresión, para alimentar máquinas automáticas de sellado y etiquetado. Diámetros y anchos según especificación de tu equipo.",
    image: "/img/productos/bobinas-pelicula-pvc-maquina-automatica.avif",
    href: "/productos/bobinas"
  },
  {
    title: "Maquinaria de Aplicación",
    description: "Fabricamos túneles de calor, pistolas industriales y sistemas de aplicación diseñados para trabajar con nuestra película PVC. Equipos robustos para producción continua.",
    image: "/img/productos/maquinaria-aplicacion-termoencogible.avif",
    href: "/productos/maquinaria"
  },
];
---

<BaseLayout
  title="Productos | Película PVC Termoencogible, Sellos y Etiquetas"
  description="Catálogo completo: sellos de garantía, mangas termoencogibles, etiquetas impresas a 6 tintas, preformados, bobinas y maquinaria de aplicación. Fabricante mexicano."
  breadcrumbs={[
    { text: "Inicio", href: "/" },
    { text: "Productos", href: "/productos" },
  ]}
>
  <TopBar />
  <Header />

  <Hero
    title="Productos de Película PVC Termoencogible"
    description="Todo lo que necesitas para sellar, etiquetar y proteger tus envases. Fabricación propia en CDMX con entrega a toda la República."
    ctaPrimary={{ text: "Cotizar Productos", href: "/cotizar" }}
    ctaSecondary={{ text: "Hablar con un Asesor", href: `https://wa.me/${WA}` }}
    seoParagraph1="Nuestra línea de productos cubre todo el espectro del empaque termoencogible: desde el sello de garantía individual hasta sistemas completos de bobina para líneas automáticas. Cada producto se fabrica en nuestra planta de Iztapalapa, CDMX, con control de calidad en calibre, encogimiento y adherencia."
    seoParagraph2="Manejamos película PVC en calibres de 40, 50, 60 y 80 micras, en colores transparente, cristal, pigmentados y con impresión a 6 tintas. Para pedidos especiales, fabricamos a la medida exacta de tu envase — diámetro, altura y forma."
  />

  <section class="section">
    <div class="container">
      <SectionHeader
        title="Catálogo de Productos"
        subtitle="Fabricación propia, calidad controlada"
        copy1="Cada producto se diseña para las dimensiones y requerimientos específicos de tu envase. No vendemos genéricos — fabricamos a tu medida."
        copy2="Pide muestras sin costo para probar en tu línea de producción antes de hacer tu pedido completo."
      />
      <div class="grid-3" style="margin-top: 3rem;">
        {productos.map(p => (
          <ServiceCard
            title={p.title}
            description={p.description}
            image={p.image}
            href={p.href}
          />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿No encuentras lo que buscas?"
    subtitle="Fabricamos productos a medida. Cuéntanos qué necesitas."
    btnText="Solicitar Cotización Personalizada"
    btnHref="/cotizar"
    variant="vibrant"
    whatsapp={WA}
  />

  <Footer
    phone="55 5686 3599"
    whatsapp={WA}
    email="ventas@sellodegarantia.com"
  />
  <WaBubble whatsapp={WA} message="Hola, necesito información sobre sus productos" tooltip="Cotizar" />
</BaseLayout>
