---
import Base from '../../layouts/Base.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBubble from '../../components/WhatsAppBubble.astro';

import { CATEGORIES } from '../../lib/config';
import { webSiteSchema } from '../../lib/seo';
---

<Base
  title="Productos PVC Termoencogible — Sellos, Mangas y Etiquetas"
  description="Catálogo de productos de PVC termoencogible: sellos de garantía, mangas retráctiles, etiquetas impresas, preformas, película en rollo y maquinaria de aplicación."
  structuredData={[webSiteSchema()]}
>
  <TopBar />
  <Header />

  <Hero
    badge="Catálogo de productos"
    title="Película PVC Termoencogible en Todas Sus Presentaciones"
    description="Fabricamos sellos, mangas, etiquetas, preformas y rollos de película de PVC termoencogible. Todo hecho a medida en calibres de 40 a 80 micras, con impresión rotograbado hasta 6 colores."
    primaryCta={{ text: 'Cotizar Producto', href: '/cotizar/' }}
    secondaryCta={{ text: 'Contactar', href: '/contacto/' }}
    metrics={[
      { value: '6', label: 'Líneas de producto' },
      { value: '4', label: 'Calibres disponibles' },
      { value: '6', label: 'Colores de impresión' },
    ]}
  >
    <Fragment slot="hero-seo">
      <div class="hero-seo">
        <p class="hero-seo__text">
          Nuestra línea de productos cubre todas las necesidades de sellado y etiquetado termoencogible para la industria mexicana. Desde sellos de garantía lisos para agua embotellada hasta mangas retráctiles full-body con impresión fotográfica de alta definición para productos premium. Cada pieza se fabrica según las medidas exactas del envase del cliente — no trabajamos con medidas estándar.
        </p>
        <p class="hero-seo__text">
          Todos nuestros productos se manufacturan en película de PVC (policloruro de vinilo) termoencogible, un material que al aplicar calor se contrae uniformemente alrededor del envase, creando un sello hermético e inviolable. Manejamos calibres de 40, 50, 60 y 80 micras que se seleccionan según el tipo de envase, la velocidad de la línea de producción y el acabado deseado.
        </p>
      </div>
    </Fragment>
  </Hero>

  <div class="container">
    <Breadcrumb items={[
      { text: 'Inicio', href: '/' },
      { text: 'Productos', href: '/productos/' },
    ]} />
  </div>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Nuestros productos"
        title="Líneas de Producto"
        subtitle="Seleccione una categoría para conocer las opciones disponibles en cada línea. Todos los productos se fabrican sobre pedido con las especificaciones que usted necesita."
      />
      <div class="grid-2">
        {CATEGORIES.map((cat) => (
          <CategoryCard
            title={cat.title}
            subtitle={cat.subtitle}
            href={`/productos/${cat.slug}/`}
            subcategories={cat.subcategories}
          />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿No encuentra lo que busca?"
    subtitle="Fabricamos sobre pedido. Cuéntenos qué necesita y lo cotizamos."
    btnText="Solicitar Cotización"
    btnHref="/cotizar/"
  />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .hero-seo {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .hero-seo__text {
    background: rgba(255, 255, 255, 0.08);
    padding: var(--space-5);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: rgba(255, 255, 255, 0.88);
  }
</style>
