---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import WaBubble from '../components/WaBubble.astro';
import '../styles/global.css';

const WA = "5215556863599";
---

<BaseLayout
  title="Cotizar Sellos de Garantía y Película PVC | Presupuesto Sin Compromiso"
  description="Solicita cotización de sellos de garantía, mangas termoencogibles, etiquetas impresas y bobinas PVC. Respuesta en menos de 2 horas. Envío de muestras gratis."
  breadcrumbs={[
    { text: "Inicio", href: "/" },
    { text: "Cotizar", href: "/cotizar" },
  ]}
>
  <TopBar />
  <Header />

  <Hero
    title="Cotiza Tu Proyecto"
    description="Cuéntanos qué necesitas y te enviamos presupuesto en menos de 2 horas. Muestras sin costo."
    ctaPrimary={{ text: "WhatsApp Rápido", href: `https://wa.me/${WA}?text=${encodeURIComponent("Hola, necesito cotizar sellos de garantía / película PVC")}` }}
    ctaSecondary={{ text: "Llamar", href: "tel:+525556863599" }}
    seoParagraph1="Para darte una cotización precisa necesitamos conocer tu envase: tipo de producto (botella, frasco, garrafón), diámetro de la tapa, altura del sello, cantidad mensual estimada y si requieres impresión. Con esos datos te enviamos precio unitario, tiempo de entrega y podemos mandarte muestras físicas sin costo."
    seoParagraph2="Si ya tienes un proveedor actual y quieres comparar precios, envíanos una muestra de tu sello actual o las especificaciones técnicas. Al ser fabricantes directos, nuestros precios son competitivos y podemos igualar o mejorar la calidad de tu producto actual."
  />

  <section class="section">
    <div class="container" style="max-width: 700px;">
      <h2 style="font-size: 1.75rem; margin-bottom: 0.5rem; text-align: center;">Formulario de Cotización</h2>
      <p style="text-align: center; color: var(--c-text-muted); margin-bottom: 2rem;">Completa los datos y te contactamos hoy</p>
      
      <form action="#" method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
        <div class="grid-2">
          <div>
            <label style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Nombre *</label>
            <input type="text" name="nombre" required style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--c-border); border-radius: var(--r-btn); font-size: 1rem;" />
          </div>
          <div>
            <label style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Empresa</label>
            <input type="text" name="empresa" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--c-border); border-radius: var(--r-btn); font-size: 1rem;" />
          </div>
        </div>
        
        <div class="grid-2">
          <div>
            <label style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Teléfono *</label>
            <input type="tel" name="telefono" required style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--c-border); border-radius: var(--r-btn); font-size: 1rem;" />
          </div>
          <div>
            <label style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Email *</label>
            <input type="email" name="email" required style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--c-border); border-radius: var(--r-btn); font-size: 1rem;" />
          </div>
        </div>
        
        <div>
          <label style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Producto que necesitas *</label>
          <select name="producto" required style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--c-border); border-radius: var(--r-btn); font-size: 1rem; background: #fff;">
            <option value="">Selecciona un producto</option>
            <option value="sellos-garantia">Sellos de Garantía</option>
            <option value="mangas">Mangas Termoencogibles</option>
            <option value="etiquetas">Etiquetas Impresas</option>
            <option value="preformados">Preformados</option>
            <option value="bobinas">Bobinas para Máquina</option>
            <option value="maquinaria">Maquinaria de Aplicación</option>
            <option value="otro">Otro / No sé</option>
          </select>
        </div>
        
        <div>
          <label style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Cantidad estimada (piezas/mes)</label>
          <select name="cantidad" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--c-border); border-radius: var(--r-btn); font-size: 1rem; background: #fff;">
            <option value="">Selecciona un rango</option>
            <option value="5000-10000">5,000 - 10,000</option>
            <option value="10000-50000">10,000 - 50,000</option>
            <option value="50000-100000">50,000 - 100,000</option>
            <option value="100000-500000">100,000 - 500,000</option>
            <option value="500000+">Más de 500,000</option>
          </select>
        </div>
        
        <div>
          <label style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Describe tu proyecto</label>
          <textarea name="mensaje" rows="4" placeholder="Tipo de envase, dimensiones, si necesitas impresión, etc." style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--c-border); border-radius: var(--r-btn); font-size: 1rem; font-family: inherit; resize: vertical;"></textarea>
        </div>
        
        <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; font-size: 1.1rem; padding: 1rem;">
          Enviar Cotización
        </button>
        <p style="text-align: center; font-size: 0.85rem; color: var(--c-text-muted);">
          Te respondemos en menos de 2 horas durante horario laboral
        </p>
      </form>
    </div>
  </section>

  <Footer
    phone="55 5686 3599"
    whatsapp={WA}
    email="ventas@sellodegarantia.com"
  />
  <WaBubble whatsapp={WA} message="Hola, necesito una cotización" tooltip="Cotizar por WA" />
</BaseLayout>
