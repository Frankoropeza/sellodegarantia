---
import Base from '../layouts/Base.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Footer from '../components/Footer.astro';
import WhatsAppBubble from '../components/WhatsAppBubble.astro';

import { SITE_NAME, PHONE, PHONE_HREF, WHATSAPP_HREF, EMAIL, HOURS, LOCATION } from '../lib/config';
import { localBusinessSchema } from '../lib/seo';
---

<Base
  title="Contacto — Ubícanos y Comunícate con Nosotros"
  description={`Contacta a ${SITE_NAME}. Teléfono: ${PHONE}. Email: ${EMAIL}. Planta en ${LOCATION.borough}, ${LOCATION.state}. Horario: ${HOURS.display}.`}
  structuredData={[localBusinessSchema()]}
>
  <TopBar />
  <Header />

  <Hero
    badge="Contacto"
    title="Hable Directo con el Fabricante"
    description="Estamos en Iztapalapa, Ciudad de México. Atendemos por teléfono, WhatsApp y correo. Si necesita cotización, también puede usar nuestro formulario de cotización."
    primaryCta={{ text: 'WhatsApp Directo', href: WHATSAPP_HREF }}
    secondaryCta={{ text: 'Solicitar Cotización', href: '/cotizar/' }}
  >
    <Fragment slot="hero-seo">
      <div class="hero-seo">
        <p class="hero-seo__text">
          La planta de Sello de Garantía (Tumipack México SA de CV) se encuentra en la 2ª Cerrada del Tercer Anillo de Circunvalación No. 12, Barrio Santa Bárbara, alcaldía Iztapalapa, Ciudad de México, CP 09000. Nuestro horario de atención es de lunes a viernes de 9:00 a 18:00 horas y sábados de 9:00 a 14:00 horas.
        </p>
        <p class="hero-seo__text">
          Para cotizaciones, preguntas técnicas sobre calibres y materiales, seguimiento de pedidos o cualquier consulta, puede comunicarse por teléfono, WhatsApp o correo electrónico. Nuestro equipo comercial responde cotizaciones el mismo día hábil en que las recibe.
        </p>
      </div>
    </Fragment>
  </Hero>

  <div class="container">
    <Breadcrumb items={[
      { text: 'Inicio', href: '/' },
      { text: 'Contacto', href: '/contacto/' },
    ]} />
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Info -->
        <div class="contact-info">
          <h2 class="contact-info__heading">Datos de Contacto</h2>

          <div class="contact-info__item">
            <span class="contact-info__icon">📞</span>
            <div>
              <p class="contact-info__label">Teléfono</p>
              <a href={PHONE_HREF} class="contact-info__value">{PHONE}</a>
            </div>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__icon">💬</span>
            <div>
              <p class="contact-info__label">WhatsApp</p>
              <a href={WHATSAPP_HREF} target="_blank" rel="noopener" class="contact-info__value">Enviar mensaje</a>
            </div>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__icon">✉️</span>
            <div>
              <p class="contact-info__label">Correo Electrónico</p>
              <a href={`mailto:${EMAIL}`} class="contact-info__value">{EMAIL}</a>
            </div>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__icon">🕐</span>
            <div>
              <p class="contact-info__label">Horario</p>
              <p class="contact-info__value">{HOURS.display}</p>
            </div>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__icon">📍</span>
            <div>
              <p class="contact-info__label">Dirección</p>
              <p class="contact-info__value">{LOCATION.full}</p>
            </div>
          </div>
        </div>

        <!-- Map placeholder -->
        <div class="contact-map">
          <div class="contact-map__embed">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3763.5!2d-99.0875!3d19.3573!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTnCsDIxJzI2LjMiTiA5OcKwMDUnMTUuMCJX!5e0!3m2!1ses!2smx!4v1"
              width="100%"
              height="400"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de Sello de Garantía en Google Maps"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .hero-seo {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .hero-seo__text {
    background: rgba(255, 255, 255, 0.08);
    padding: var(--space-5);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: rgba(255, 255, 255, 0.88);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }
  .contact-info__heading {
    font-size: var(--font-size-2xl);
    color: var(--color-gray-900);
    margin-bottom: var(--space-8);
  }
  .contact-info__item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    margin-bottom: var(--space-6);
  }
  .contact-info__icon {
    font-size: var(--font-size-xl);
    flex-shrink: 0;
  }
  .contact-info__label {
    font-size: var(--font-size-sm);
    color: var(--color-gray-600);
    margin-bottom: var(--space-1);
  }
  .contact-info__value {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-gray-900);
  }
  a.contact-info__value:hover {
    color: var(--color-primary);
  }
  .contact-map__embed {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-gray-200);
  }
  .contact-map__embed iframe {
    display: block;
  }
  @media (min-width: 768px) {
    .contact-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
