---
import Base from '../layouts/Base.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import IndustryCard from '../components/IndustryCard.astro';
import CtaBanner from '../components/CtaBanner.astro';
import FaqSection from '../components/FaqSection.astro';
import Footer from '../components/Footer.astro';
import WhatsAppBubble from '../components/WhatsAppBubble.astro';

import { SITE_NAME, CATEGORIES, INDUSTRIES } from '../lib/config';
import { organizationSchema, localBusinessSchema, webSiteSchema, faqSchema } from '../lib/seo';

const faqs = [
  {
    question: '¿Qué calibres de película de PVC manejan?',
    answer: 'Trabajamos con calibres de 40, 50, 60 y 80 micras. El calibre se elige según el tipo de envase, la velocidad de la línea de producción y el acabado que necesite el producto. Nuestro equipo técnico le asesora para elegir el calibre correcto.',
  },
  {
    question: '¿Cuál es el pedido mínimo para sellos de garantía?',
    answer: 'Fabricamos desde tirajes cortos para pruebas de producto hasta volúmenes industriales de millones de piezas. El mínimo varía según si el sello es liso o impreso. Contáctenos con los datos de su proyecto para darle una cotización precisa.',
  },
  {
    question: '¿Pueden imprimir el logotipo de mi empresa en los sellos?',
    answer: 'Sí. Contamos con impresión por rotograbado en hasta 6 colores. Podemos reproducir su logotipo, texto legal, código de barras, y cualquier diseño que necesite sobre la película de PVC. También ofrecemos apoyo en diseño.',
  },
  {
    question: '¿Qué tiempo de entrega manejan?',
    answer: 'Los sellos lisos (sin impresión) se entregan en 3 a 5 días hábiles. Los sellos impresos tardan entre 10 y 15 días hábiles dependiendo de la complejidad del diseño y el volumen. Para proyectos urgentes, consulte disponibilidad.',
  },
  {
    question: '¿Hacen envíos a toda la República Mexicana?',
    answer: 'Sí, tenemos cobertura nacional. Enviamos a los 32 estados de México por paquetería y transporte de carga. Para pedidos en la Ciudad de México y zona metropolitana ofrecemos entrega directa.',
  },
  {
    question: '¿También venden maquinaria para aplicar los sellos?',
    answer: 'Sí. Fabricamos y distribuimos túneles de calor y aplicadoras automáticas y semiautomáticas compatibles con nuestros sellos y mangas. También damos servicio de mantenimiento y refacciones.',
  },
  {
    question: '¿Para qué industrias trabajan?',
    answer: 'Atendemos farmacéutica, alimentos y bebidas, agua embotellada, vinos y licores, productos naturales, gas, papelería y juguetes. Cada industria tiene requerimientos específicos de sellado que conocemos a detalle.',
  },
];

const structuredData = [
  organizationSchema(),
  localBusinessSchema(),
  webSiteSchema(),
  faqSchema(faqs),
];

const features = [
  { title: 'Planta propia en CDMX', description: 'Fabricación directa en nuestra planta de Iztapalapa. Sin intermediarios, sin sobreprecios. Usted trata directamente con el fabricante.' },
  { title: 'Fabricación a la medida de su envase', description: 'Cada sello, manga y etiqueta se manufactura según las dimensiones exactas de su envase. No vendemos medidas genéricas.' },
  { title: 'Impresión rotograbado a 6 tintas', description: 'Alta definición en hasta 6 colores. Logotipos, textos legales, códigos de barras — todo en una sola película.' },
  { title: 'Maquinaria de aplicación incluida', description: 'Fabricamos túneles de calor y aplicadoras. Le equipamos la línea completa: película + maquinaria + servicio técnico.' },
  { title: 'Envíos a los 32 estados', description: 'Cobertura nacional por paquetería y transporte de carga. Entrega directa en CDMX y zona metropolitana.' },
  { title: '28 años en el mercado', description: 'Desde 1998 fabricando película termoencogible para farmacéutica, alimentos, bebidas, gas y más sectores industriales.' },
];
---

<Base
  title={`${SITE_NAME} — Fabricantes de Película PVC Termoencogible y Sellos de Garantía en México`}
  description="Fabricamos sellos de garantía, mangas retráctiles, etiquetas impresas y película de PVC termoencogible. 28 años de experiencia, impresión 6 tintas, cobertura nacional."
  structuredData={structuredData}
>
  <TopBar />
  <Header />

  <Hero
    badge="Fabricantes desde 1998"
    title="Sellos de Garantía y Película PVC Termoencogible"
    description="Fabricamos sellos de garantía, mangas retráctiles, etiquetas impresas y película termoencogible de PVC en calibres de 40 a 80 micras. Impresión rotograbado hasta 6 colores. Planta propia en CDMX con cobertura a toda la República."
    primaryCta={{ text: 'Solicitar Cotización', href: '/cotizar/' }}
    secondaryCta={{ text: 'Ver Productos', href: '/productos/' }}
    metrics={[
      { value: '28', label: 'Años' },
      { value: '6', label: 'Tintas' },
      { value: '4', label: 'Calibres' },
      { value: '32', label: 'Estados' },
    ]}
  >
    <Fragment slot="hero-seo">
      <div class="hero-seo">
        <p class="hero-seo__text">
          En Sello de Garantía fabricamos película de PVC termoencogible para la industria del empaque en México. Nuestros sellos de garantía protegen la inviolabilidad de productos farmacéuticos, alimenticios, de bebidas, vinos, licores y productos naturales. Trabajamos con calibres de 40, 50, 60 y 80 micras según las necesidades de cada línea de producción, y ofrecemos impresión por rotograbado en hasta 6 colores para personalizar cada pieza con logotipos, datos legales y diseño de marca.
        </p>
        <p class="hero-seo__text">
          Somos fabricantes directos con planta propia en la Ciudad de México. Eso significa precios de fábrica, control total de calidad y tiempos de entrega que cumplimos. Además de sellos y mangas, manufacturamos maquinaria de aplicación — túneles de calor y aplicadoras — para que su línea de empaque funcione completa desde un solo proveedor. Atendemos a empresas en los 32 estados de la República Mexicana.
        </p>
      </div>
    </Fragment>
  </Hero>

  <!-- CTA Post-Hero -->
  <CtaBanner
    title="¿Busca un fabricante de sellos de garantía?"
    subtitle="Cotización en menos de 24 horas. Muestras sin costo."
    btnText="Cotizar Ahora"
    btnHref="/cotizar/"
    variant="accent"
  />

  <!-- Products Section -->
  <section class="section" id="productos">
    <div class="container">
      <SectionHeader
        badge="Productos"
        title="Lo Que Fabricamos"
        subtitle="Película de PVC termoencogible en todas sus presentaciones: sellos, mangas, etiquetas, preformas y rollos. Todo hecho a medida en nuestra planta."
      />
      <div class="grid-3">
        {CATEGORIES.map((cat) => (
          <CategoryCard
            title={cat.title}
            subtitle={cat.subtitle}
            href={`/productos/${cat.slug}/`}
            subcategories={cat.subcategories}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Industries Section -->
  <section class="section" style="background: var(--color-gray-50);" id="industrias">
    <div class="container">
      <SectionHeader
        badge="Industrias"
        title="Sectores Que Atendemos"
        subtitle="Cada industria tiene requerimientos específicos de sellado, calibre y resistencia. Conocemos los de cada una porque llevamos 28 años trabajando con ellas."
      />
      <div class="grid-4">
        {INDUSTRIES.slice(0, 8).map((ind) => (
          <IndustryCard
            title={ind.name}
            description={ind.description}
            href={ind.href}
            image={ind.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section" id="ventajas">
    <div class="container">
      <SectionHeader
        badge="¿Por qué elegirnos?"
        title="Fabricante Directo, Sin Intermediarios"
        subtitle="Cada pieza sale de nuestra planta. Controlamos materiales, impresión, corte y entrega. Así garantizamos calidad y precio."
      />
      <div class="trust-grid">
        {features.map((f) => (
          <div class="trust-item">
            <h3 class="trust-item__title">{f.title}</h3>
            <p class="trust-item__desc">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CtaBanner
    title="¿Necesita sellos de garantía para su producto?"
    subtitle="Cotice sin compromiso. Le respondemos el mismo día."
    btnText="Solicitar Cotización"
    btnHref="/cotizar/"
    variant="accent"
  />

  <!-- FAQ -->
  <section class="section" id="faq">
    <SectionHeader
      badge="Preguntas Frecuentes"
      title="Lo Que Nuestros Clientes Preguntan"
      subtitle="Las dudas más comunes sobre nuestros sellos, mangas, impresión y tiempos de entrega."
    />
    <FaqSection items={faqs} />
  </section>

  <!-- CTA Pre-Footer -->
  <CtaBanner
    title="Listo para proteger su producto"
    subtitle="28 años de experiencia respaldan cada sello que fabricamos. Hablemos de su proyecto."
    btnText="Contactar Ahora"
    btnHref="/contacto/"
    variant="primary"
  />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .hero-seo {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .hero-seo__text {
    background: rgba(255, 255, 255, 0.08);
    padding: var(--space-5);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: rgba(255, 255, 255, 0.88);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 640px) {
    .trust-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .trust-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .trust-item {
    padding: var(--space-5) var(--space-6);
    border-left: 3px solid var(--color-primary, #0047AB);
    background: var(--color-gray-50, #F8FAFC);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  .trust-item__title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
    margin-bottom: 0.25rem;
  }
  .trust-item__desc {
    font-size: var(--font-size-sm);
    color: var(--color-gray-600);
    line-height: var(--line-height-relaxed);
  }
  .faq-list {
    max-width: 800px;
  }
</style>
