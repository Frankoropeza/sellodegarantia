---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { SITE_URL } from '../../lib/config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, heroImage, heroImageAlt, category, faqs, publishDate } = post.data;

const canonical = `${SITE_URL}blog/${post.id}/`;

const schemas: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: description,
    author: { '@type': 'Organization', name: 'Tumipack México', url: SITE_URL },
    publisher: {
      '@type': 'Organization',
      name: 'Tumipack México',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: `${SITE_URL}img/logo.avif` },
    },
    image: `${SITE_URL}${heroImage.replace(/^\//, '')}`,
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    datePublished: publishDate.toISOString().split('T')[0],
    dateModified: publishDate.toISOString().split('T')[0],
  },
];

if (faqs && faqs.length > 0) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  });
}

schemas.push({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Tumipack México',
  url: SITE_URL,
  telephone: '+525556863599',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Iztapalapa',
    addressRegion: 'CDMX',
    addressCountry: 'MX',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    bestRating: '5',
    ratingCount: '47',
  },
});

const schemaMarkup = JSON.stringify(schemas);
---

<BlogLayout
  title={title}
  description={description}
  canonical={canonical}
  image={heroImage}
  imageAlt={heroImageAlt || title}
  category={category}
  schemaMarkup={schemaMarkup}
>
  <Content />
</BlogLayout>
